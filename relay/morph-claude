#!/bin/bash
# morph-claude — wrapper that registers terminal claude sessions with morph relay
# Usage: morph-claude [claude args...]
#
# Runs `claude` in the foreground (interactive TTY preserved).
# A background monitor detects the session ID from /proc/<pid>/fd and
# registers it with the relay so it appears as a first-class session.
# On exit, deregisters automatically.

RELAY_URL="${MORPH_RELAY_URL:-http://localhost:3001}"
RELAY_TOKEN="${MORPH_RELAY_TOKEN:-morph2026}"
SID_FILE=$(mktemp /tmp/morph-claude-XXXXXX)

# Background monitor: find claude child PID, extract session ID, register
WRAPPER_PID=$$
(
  sleep 3  # wait for claude to initialize and open session file

  # Find claude process that's a child of the wrapper
  CLAUDE_PID=$(pgrep -P $WRAPPER_PID claude 2>/dev/null | head -1)
  if [ -z "$CLAUDE_PID" ]; then
    # Fallback: find claude whose PPID matches wrapper or was started recently
    CLAUDE_PID=$(ps -eo pid,ppid,etimes,comm 2>/dev/null | awk -v wp=$WRAPPER_PID '$4=="claude" && ($2==wp || $3<10){print $1}' | tail -1)
  fi
  if [ -z "$CLAUDE_PID" ]; then
    echo "[morph-claude] ❌ could not find claude child (wrapper=$WRAPPER_PID)" >> /tmp/morph-claude-debug.log
    exit 0
  fi
  echo "[morph-claude] found claude PID=$CLAUDE_PID (wrapper=$WRAPPER_PID)" >> /tmp/morph-claude-debug.log

  # Extract session ID from open file descriptors (Linux: /proc/pid/fd)
  SID=""
  for attempt in 1 2 3 4 5; do
    SID=$(readlink /proc/$CLAUDE_PID/fd/* 2>/dev/null | grep -oP '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}(?=\.jsonl)' | head -1)
    [ -n "$SID" ] && break
    sleep 2
  done
  if [ -z "$SID" ]; then
    echo "[morph-claude] ❌ could not extract session ID from PID=$CLAUDE_PID fds" >> /tmp/morph-claude-debug.log
    # Debug: dump fd links
    readlink /proc/$CLAUDE_PID/fd/* 2>/dev/null >> /tmp/morph-claude-debug.log
    exit 0
  fi
  echo "[morph-claude] session=$SID" >> /tmp/morph-claude-debug.log

  echo "$SID" > "$SID_FILE"

  # Register with relay
  curl -s -X POST "$RELAY_URL/v2/claude/register" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $RELAY_TOKEN" \
    -d "{\"pid\": $CLAUDE_PID, \"sessionId\": \"$SID\"}" >/dev/null 2>&1
) &
MONITOR_PID=$!

# Strip env vars that interfere with OAuth/Max plan auth
unset CLAUDECODE
unset ANTHROPIC_API_KEY

# Run claude foreground — full TTY passthrough
claude "$@"
EXIT_CODE=$?

# Cleanup monitor
kill $MONITOR_PID 2>/dev/null
wait $MONITOR_PID 2>/dev/null

# Deregister session
SID=$(cat "$SID_FILE" 2>/dev/null)
if [ -n "$SID" ]; then
  curl -s -X POST "$RELAY_URL/v2/claude/deregister" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $RELAY_TOKEN" \
    -d "{\"sessionId\": \"$SID\"}" >/dev/null 2>&1
fi

# Cleanup temp file (use mv to trash per safety rules)
[ -f "$SID_FILE" ] && mv "$SID_FILE" /tmp/.morph-claude-trash/ 2>/dev/null || true

exit $EXIT_CODE
